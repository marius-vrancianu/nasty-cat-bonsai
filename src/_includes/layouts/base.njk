<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <script>try{if(localStorage.getItem("theme")==="dark")document.documentElement.dataset.theme="dark"}catch(e){}</script>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {#- Tints mobile browser chrome to match the paper. theme.js swaps the
      value when the visitor toggles dark mode (values mirror --washi). #}
  <meta name="theme-color" content="#f2ece0">
  <title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {#- Share-preview cards (Open Graph + Twitter). Posts use their thumb
      image and excerpt; every other page falls back to the hero and the
      site description. All URLs must be absolute — scrapers don't
      resolve relative paths. #}
  {%- set isPost = tags and "posts" in tags %}
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:type" content="{{ "article" if isPost else "website" }}">
  <meta property="og:title" content="{{ title or site.name }}">
  <meta property="og:description" content="{{ description or excerpt or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  {%- if thumb %}
  <meta property="og:image" content="{{ site.images.cdn }}{{ thumb }}">
  {%- else %}
  <meta property="og:image" content="{{ site.url }}/assets/img/hero.jpg">
  <meta property="og:image:width" content="1134">
  <meta property="og:image:height" content="1286">
  {%- endif %}
  {%- if isPost %}
  <meta property="article:published_time" content="{{ page.date | rfc3339 }}">
  {%- endif %}
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  {#- The body face, fetched in parallel with the CSS instead of after it —
      shortens the flash of fallback Georgia on first visit. `crossorigin`
      is required on font preloads even same-origin, or the browser
      refetches the file. #}
  <link rel="preload" href="/assets/fonts/proza-libre-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/assets/css/fonts.css">
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="alternate" type="application/atom+xml" title="{{ site.name }}" href="/feed.xml">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
{{ content | safe }}
{% include "partials/consent-banner.njk" %}
<script src="/assets/js/theme.js" defer></script>
{%- if site.analytics.gaMeasurementId %}
<script src="/assets/js/consent.js" defer></script>
{%- endif %}
</body>
</html>
