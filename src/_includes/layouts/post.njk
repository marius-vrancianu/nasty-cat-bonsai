---
layout: layouts/base.njk
---
<div class="page">
  <header class="site-header">
    <a class="back-link" href="/blog/">&larr; Blog</a>
    {% include "partials/theme-toggle.njk" %}
  </header>
  <main class="page-main">
    <article class="post">
      <div class="post-date">{{ page.date | readableDate }}</div>
      <h1 class="post-title">{{ title }}</h1>
      {{ content | safe }}

      {# Cusdis comments — anonymous nickname + comment, no login.
         Activated by setting comments.cusdisAppId in src/_data/site.js
         (App ID from the cusdis.com dashboard). data-page-id is the post's
         URL path, so each post gets its own thread. #}
      {% if site.comments.cusdisAppId %}
      <section class="comments" aria-label="Comments">
        <h2 class="comments-title">Comments</h2>
        <div id="cusdis_thread"
             data-theme="light"
             data-host="https://cusdis.com"
             data-app-id="{{ site.comments.cusdisAppId }}"
             data-page-id="{{ page.url }}"
             data-page-url="{{ site.url }}{{ page.url }}"
             data-page-title="{{ title }}"></div>
        <script async defer src="https://cusdis.com/js/cusdis.es.js"></script>
      </section>
      {% else %}
      <div class="comments-placeholder">Comments load here once Cusdis is configured — see src/_data/site.js.</div>
      {% endif %}
    </article>
  </main>
  {% include "partials/footer.njk" %}
</div>
