---
layout: layouts/base.njk
bodyClass: home-body
---
<div class="home">
  {#- The visible title lives inside the hero artwork; this gives screen
      readers and search engines a real page heading. #}
  <h1 class="visually-hidden">Nasty Cat Bonsai</h1>
  {% include "partials/theme-toggle.njk" %}
  <div class="home-pines" aria-hidden="true"></div>
  {# AVIF → WebP → JPEG, largest-first per format; phones (which display
     the hero at ~100vw ≈ 390–430 CSS px) get the 800px encodes. The
     desktop `sizes` value is the image's rendered width: 91.9dvh tall
     (see .hero-frame) × the 1134/1286 aspect ratio ≈ 81vh. #}
  <div class="hero-frame">
    <picture>
      <source type="image/avif"
              srcset="/assets/img/hero-800.avif 800w, /assets/img/hero.avif 1134w"
              sizes="(max-width: 767px) 100vw, 81vh">
      <source type="image/webp"
              srcset="/assets/img/hero-800.webp 800w, /assets/img/hero.webp 1134w"
              sizes="(max-width: 767px) 100vw, 81vh">
      <img class="home-hero" src="/assets/img/hero.jpg"
           width="1134" height="1286" fetchpriority="high"
           alt="Ukiyo-e style illustration of a cat perched above a knocked-over red maple bonsai, with the artist's name in katakana">
    </picture>
  </div>
  <nav class="home-nav" aria-label="Main">
    <a href="/about/">about</a>
    <a href="/blog/">blog</a>
    <a href="/gallery/">gallery</a>
    <div class="home-social">
      <a href="{{ site.social.facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.4v7A10 10 0 0 0 22 12z"/></svg>
      </a>
      <a href="{{ site.social.instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="mailto:{{ site.email }}" aria-label="Email">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m3 6 9 7 9-7"/></svg>
      </a>
      <a href="/feed.xml" aria-label="RSS feed">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1.4" fill="currentColor" stroke="none"/></svg>
      </a>
      <a class="footer-text-link" href="/privacy/">privacy</a>
      {%- if site.analytics.gaMeasurementId %}
      <button class="cookie-settings" type="button" hidden>cookie settings</button>
      {%- endif %}
    </div>
  </nav>
</div>
